# =============================================================================
#  EVERYTHING HERE IS FREE TIER. Total cost: $0 plus your existing OpenAI credit.
# =============================================================================

# ---------- Core ----------
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- Database: plain Postgres. Neon free tier (~0.5 GB, no idle pause) ----------
# neon.tech -> new project -> Connection string (pooled)
#
# This ONE database is everything: the data (Drizzle), the job queue (pg-boss), the
# vector store (pgvector), AND the compressed crawl artefacts. No object store.
#
# Nothing in the code knows it is talking to Neon. This connection string is the entire
# integration surface, so any Postgres works: Render, RDS, or one in a container.
# See ADR-0007.
DATABASE_URL=postgresql://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/seo?sslmode=require

# ---------- Encryption (for OAuth refresh tokens at rest) ----------
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# =============================================================================
#  LLM: addressed by ROLE, never by vendor. See packages/llm/README.md
#
#  Syntax:  LLM_<ROLE>=provider:model[,provider:model,...]
#  Comma separated = ordered fallback chain (tried on 429 / quota / 5xx).
#  Targets whose API key is missing are SILENTLY DROPPED, so you can list
#  providers you do not have keys for yet. Nothing breaks.
#
#  Adding a key later = edit this file. Never touch code.
# =============================================================================

# You have OpenAI credit, so lead with OpenAI, and list free fallbacks behind it.
# Once you add GROQ_API_KEY or GOOGLE_GENERATIVE_AI_API_KEY, they activate automatically.
LLM_FAST=openai:gpt-4.1-mini,groq:llama-3.3-70b-versatile,google:gemini-2.0-flash
LLM_SMART=openai:gpt-4.1,google:gemini-2.5-pro
LLM_EMBED=openai:text-embedding-3-small,google:text-embedding-004

# The eval-harness judge MUST be a different family than the model under test,
# or you get self-preference bias and your precision numbers lie to you.
LLM_JUDGE=google:gemini-2.5-pro

# ---- Keys. Set only the ones you have. ----
OPENAI_API_KEY=sk-...
# aistudio.google.com/apikey  (free tier, generous)
GOOGLE_GENERATIVE_AI_API_KEY=
# console.groq.com/keys  (free tier, very fast)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Local models: ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
# Any OpenAI-compatible endpoint: LLM_FAST=custom:model@https://host/v1
CUSTOM_LLM_API_KEY=

# =============================================================================
#  Google APIs. All free. ONE Cloud project, ONE OAuth client covers them all.
#  console.cloud.google.com -> new project -> APIs & Services -> Library -> enable:
#    Search Console API, Site Verification API, PageSpeed Insights API,
#    Chrome UX Report API, Google Analytics Data API
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/auth/google/callback
# Server-key APIs, no OAuth needed. Same project -> Credentials -> Create API key.
GOOGLE_PSI_API_KEY=
GOOGLE_CRUX_API_KEY=

# ---------- Bing Webmaster Tools: FREE, and gives you BACKLINK DATA ----------
# bing.com/webmasters -> Settings -> API access -> generate key
# This is your free backlink source. Massively underused.
BING_WEBMASTER_API_KEY=

# ---------- GitHub App (sprint 2) ----------
# github.com/settings/apps/new
# Permissions: contents:write, pull_requests:write, metadata:read, checks:read
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# For dispatching worker jobs to GitHub Actions (see ADR-0006)
GITHUB_WORKER_REPO=youruser/seo-agent
GITHUB_WORKER_TOKEN=

# ---------- SERP data (sprint 3) ----------
# SerpApi: 250 searches/month FREE. Ration them: 5 prompts x 3 polls x 4 weeks = 60.
SERPAPI_KEY=
SERPAPI_MONTHLY_BUDGET=250
# DataForSEO: free sandbox returns fake data but exercises the full integration path.
# Build against the sandbox now, top up $50 when you have revenue.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_USE_SANDBOX=true

# ---------- Budget guards (enforced BEFORE the call, not after) ----------
MAX_USD_PER_TENANT_PER_DAY=1
MAX_PAGES_PER_CRAWL=500
MAX_FILES_PER_PR=10
