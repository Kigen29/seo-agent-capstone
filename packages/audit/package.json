{
  "name": "@seo/audit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit:run": "node --env-file-if-exists=../../.env dist/cli.js"
  },
  "dependencies": {
    "@seo/core": "workspace:*",
    "@seo/crawler": "workspace:*",
    "@seo/db": "workspace:*",
    "@seo/rules": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@seo/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.0.0"
  }
}
